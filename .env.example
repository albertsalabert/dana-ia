# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Auth (magic links)
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres aleatorios)
AUTH_SECRET=cambia-esto-por-una-clave-segura-de-32-chars

# Email (para enviar magic links)
# Opción 1: SMTP propio
SMTP_HOST=smtp.tuempresa.com
SMTP_PORT=587
SMTP_USER=noreply@tuempresa.com
SMTP_PASS=tu-contraseña-smtp
SMTP_FROM=IA Corporativa <noreply@tuempresa.com>

# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_NAME=Mi Empresa

# Admin inicial (email del primer administrador)
ADMIN_EMAIL=admin@tuempresa.com
